# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# For Supabase: Settings → Database → Connection String (use "Transaction" pooler for serverless)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the Express server listens on (Railway/Render set this automatically)
PORT=8080

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# ─── Optional ────────────────────────────────────────────────────────────────

# JWT signing secret — change this in production!
JWT_SECRET=change-me-in-production

# Allowed CORS origin for your Vercel frontend (defaults to * if not set)
# Example: https://arogyaai.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
