{
  "buildCommand": "pnpm --filter @workspace/arogyaai run build",
  "outputDirectory": "artifacts/arogyaai/dist/public",
  "installCommand": "corepack enable && corepack prepare pnpm@10.26.1 --activate && pnpm install",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
