{
  "buildCommand": "npx --yes pnpm@10 --filter @workspace/arogyaai run build",
  "outputDirectory": "artifacts/arogyaai/dist/public",
  "installCommand": "npx --yes pnpm@10 install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

